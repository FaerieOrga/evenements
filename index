<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Événements de Faérie — Dates</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=IM+Fell+English:ital@0;1&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --parchment:    #f2e8c9;
  --parchment-dk: #e0ceA0;
  --ink:          #2a1a0a;
  --ink-light:    #5c3d1e;
  --red-blood:    #8b1a1a;
  --gold:         #9a7b2f;
  --gold-light:   #c9a84c;
  --border:       #6b4c1e;
  --shadow:       rgba(30,15,5,0.45);
  --bg-img:       url('https://drive.google.com/uc?export=view&id=142vQlX6NsPL118l3x-VHn9iNx94Vydng');
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  min-height: 100vh;
  background: #1a0f05 var(--bg-img) center/cover fixed;
  font-family: 'Crimson Text', Georgia, serif;
  color: var(--ink);
  font-size: 16px;
  line-height: 1.6;
}
body::before {
  content: '';
  position: fixed; inset: 0;
  background: rgba(10,5,2,0.55);
  pointer-events: none;
  z-index: 0;
}

#app {
  position: relative;
  z-index: 1;
  max-width: 900px;
  margin: 0 auto;
  padding: 20px 16px 60px;
}

.parchment {
  background: var(--parchment) var(--bg-img) center/cover;
  border: 3px solid var(--border);
  border-radius: 4px;
  padding: 36px 40px;
  box-shadow: 0 0 0 1px var(--gold), 0 8px 32px var(--shadow), inset 0 0 80px rgba(160,120,40,0.18);
  position: relative;
  overflow: hidden;
}
.parchment::before, .parchment::after {
  content: '✦';
  position: absolute;
  font-size: 28px;
  color: var(--gold);
  opacity: 0.7;
  line-height: 1;
}
.parchment::before { top: 10px; left: 14px; }
.parchment::after  { bottom: 10px; right: 14px; }

/* ── LOGIN ── */
#login-screen { text-align: center; padding: 20px 0; }
.login-title {
  font-family: 'Cinzel', serif;
  font-size: 2.2rem;
  font-weight: 700;
  color: var(--ink);
  text-shadow: 1px 1px 0 var(--gold-light);
  margin-bottom: 6px;
  letter-spacing: 2px;
}
.login-subtitle {
  font-family: 'IM Fell English', serif;
  font-style: italic;
  color: var(--ink-light);
  font-size: 1.1rem;
  margin-bottom: 30px;
}
.divider { border: none; border-top: 1px solid var(--gold); margin: 20px 0; opacity: 0.6; }
.divider-ornament { text-align: center; color: var(--gold); font-size: 1.1rem; margin: -12px 0 20px; }

.tab-switch {
  display: flex;
  gap: 0;
  margin-bottom: 28px;
  border: 1px solid var(--border);
  border-radius: 3px;
  overflow: hidden;
}
.tab-switch button {
  flex: 1;
  padding: 10px;
  background: rgba(160,120,40,0.1);
  border: none;
  border-right: 1px solid var(--border);
  font-family: 'Cinzel', serif;
  font-size: 0.85rem;
  letter-spacing: 1px;
  color: var(--ink-light);
  cursor: pointer;
  transition: background 0.2s, color 0.2s;
}
.tab-switch button:last-child { border-right: none; }
.tab-switch button.active { background: var(--gold); color: #fff; font-weight: 600; }

/* ── FORMS ── */
.form-group { margin-bottom: 18px; text-align: left; }
label {
  display: block;
  font-family: 'Cinzel', serif;
  font-size: 0.78rem;
  letter-spacing: 1.5px;
  color: var(--ink-light);
  margin-bottom: 5px;
  text-transform: uppercase;
}
input[type="text"], input[type="email"], input[type="password"], input[type="url"],
input[type="date"], input[type="number"], select, textarea {
  width: 100%;
  background: rgba(242,232,201,0.6);
  border: 1px solid var(--border);
  border-radius: 2px;
  padding: 9px 12px;
  font-family: 'Crimson Text', serif;
  font-size: 1rem;
  color: var(--ink);
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
}
input:focus, select:focus, textarea:focus {
  border-color: var(--gold);
  box-shadow: 0 0 0 2px rgba(154,123,47,0.2);
}
textarea { min-height: 100px; resize: vertical; line-height: 1.7; }

/* ── BOUTONS ── */
.btn {
  display: inline-block;
  padding: 10px 28px;
  background: var(--ink);
  color: var(--parchment);
  border: 1px solid var(--gold);
  border-radius: 2px;
  font-family: 'Cinzel', serif;
  font-size: 0.85rem;
  letter-spacing: 2px;
  cursor: pointer;
  text-transform: uppercase;
  transition: background 0.2s, color 0.2s;
}
.btn:hover { background: var(--gold); color: var(--ink); }
.btn-full  { width: 100%; text-align: center; }
.btn-sm    { padding: 6px 16px; font-size: 0.75rem; }
.btn-danger { background: var(--red-blood); border-color: var(--red-blood); color: #fff; }
.btn-danger:hover { background: #6b0f0f; }
.btn-orga { background: var(--red-blood); }
.btn-orga:hover { background: #6b0f0f; }
.btn-ghost {
  background: transparent;
  border: 1px solid var(--border);
  color: var(--ink-light);
  padding: 6px 14px;
  font-family: 'Cinzel', serif;
  font-size: 0.75rem;
  cursor: pointer;
  border-radius: 2px;
  transition: background 0.2s;
}
.btn-ghost:hover { background: rgba(154,123,47,0.15); }

/* ── MESSAGES ── */
.msg-error {
  background: rgba(139,26,26,0.12);
  border: 1px solid var(--red-blood);
  color: var(--red-blood);
  padding: 8px 14px;
  border-radius: 2px;
  font-size: 0.9rem;
  margin-top: 10px;
  display: none;
}
.msg-success {
  background: rgba(47,100,47,0.12);
  border: 1px solid #3a6b3a;
  color: #2a4a2a;
  padding: 8px 14px;
  border-radius: 2px;
  font-size: 0.9rem;
  margin-top: 10px;
  display: none;
}

/* ── LOGOUT BAR ── */
.logout-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
  padding: 10px 16px;
  background: rgba(30,15,5,0.7);
  border: 1px solid var(--gold);
  color: var(--parchment);
}
.logout-bar span { font-family: 'Cinzel', serif; font-size: 0.78rem; letter-spacing: 1px; }

/* ── DASHBOARD TITRE ── */
.dashboard-title {
  font-family: 'Cinzel', serif;
  font-size: 1.5rem;
  font-weight: 700;
  letter-spacing: 2px;
  color: var(--ink);
  margin-bottom: 6px;
}
.dashboard-subtitle {
  font-family: 'IM Fell English', serif;
  font-style: italic;
  color: var(--ink-light);
  margin-bottom: 28px;
  font-size: 1rem;
}

/* ── SECTION TITLE ── */
.section-title {
  font-family: 'IM Fell English', serif;
  font-size: 1.4rem;
  color: var(--ink);
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.section-title::before { content: '➤'; color: var(--gold); font-size: 1rem; }

/* ── CARTES ÉVÉNEMENTS ── */
.events-grid {
  display: flex;
  flex-direction: column;
  gap: 18px;
}
.event-card {
  border: 1px solid var(--border);
  background: rgba(255,255,255,0.12);
  padding: 0;
  transition: box-shadow 0.2s, transform 0.15s;
  position: relative;
  overflow: hidden;
}
.event-card:hover { box-shadow: 0 4px 20px var(--shadow); transform: translateY(-1px); }
.event-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16px 20px 12px;
  border-bottom: 1px solid rgba(107,76,30,0.25);
  gap: 12px;
  flex-wrap: wrap;
}
.event-card-titre {
  font-family: 'Cinzel', serif;
  font-size: 1.05rem;
  font-weight: 600;
  color: var(--ink);
  flex: 1;
}
.event-card-type {
  display: inline-block;
  padding: 3px 12px;
  border: 1px solid var(--border);
  border-radius: 2px;
  font-family: 'Cinzel', serif;
  font-size: 0.68rem;
  letter-spacing: 1px;
  background: rgba(154,123,47,0.15);
  color: var(--ink-light);
  white-space: nowrap;
}
.event-card-body {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 10px;
  padding: 14px 20px;
}
.event-info-item { display: flex; flex-direction: column; gap: 2px; }
.event-info-label {
  font-family: 'Cinzel', serif;
  font-size: 0.65rem;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--ink-light);
}
.event-info-val {
  font-family: 'Crimson Text', serif;
  font-size: 0.97rem;
  color: var(--ink);
}
.event-card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 20px 14px;
  border-top: 1px solid rgba(107,76,30,0.2);
  gap: 10px;
  flex-wrap: wrap;
}

/* Jauge de places */
.jauge-wrap { display: flex; align-items: center; gap: 8px; }
.jauge-bar {
  width: 120px;
  height: 6px;
  background: rgba(107,76,30,0.2);
  border-radius: 3px;
  overflow: hidden;
}
.jauge-fill {
  height: 100%;
  background: var(--gold);
  border-radius: 3px;
  transition: width 0.4s;
}
.jauge-fill.complet { background: var(--red-blood); }
.jauge-text {
  font-family: 'Cinzel', serif;
  font-size: 0.72rem;
  color: var(--ink-light);
  white-space: nowrap;
}

/* Badge liste attente */
.badge-attente {
  background: rgba(139,26,26,0.12);
  border: 1px solid var(--red-blood);
  color: var(--red-blood);
  font-family: 'Cinzel', serif;
  font-size: 0.68rem;
  letter-spacing: 1px;
  padding: 2px 10px;
  border-radius: 2px;
}

/* ── TABLE ORGA ── */
.orga-table { width: 100%; border-collapse: collapse; font-size: 0.92rem; }
.orga-table th {
  font-family: 'Cinzel', serif;
  font-size: 0.72rem;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--ink-light);
  border-bottom: 2px solid var(--gold);
  padding: 8px 10px;
  text-align: left;
}
.orga-table td { padding: 8px 10px; border-bottom: 1px solid rgba(107,76,30,0.2); vertical-align: middle; }
.orga-table tr:hover td { background: rgba(154,123,47,0.06); }
.orga-toolbar { display: flex; gap: 10px; align-items: center; margin-bottom: 20px; flex-wrap: wrap; }

/* ── MODALES ── */
.modal-overlay {
  display: none;
  position: fixed; inset: 0;
  background: rgba(10,5,2,0.75);
  z-index: 100;
  align-items: center;
  justify-content: center;
  padding: 16px;
}
.modal-overlay.open { display: flex; }
.modal-box {
  background: var(--parchment) var(--bg-img) center/cover;
  border: 2px solid var(--border);
  box-shadow: 0 0 0 1px var(--gold), 0 12px 48px rgba(0,0,0,0.6);
  padding: 30px 34px;
  max-width: 600px;
  width: 100%;
  max-height: 90vh;
  overflow-y: auto;
  position: relative;
}
.modal-title { font-family: 'Cinzel', serif; font-size: 1.2rem; font-weight: 700; margin-bottom: 20px; color: var(--ink); }
.modal-close { position: absolute; top: 12px; right: 16px; background: none; border: none; font-size: 1.4rem; color: var(--ink-light); cursor: pointer; }

/* ── TOAST ── */
.toast {
  position: fixed;
  bottom: 24px; right: 24px;
  background: var(--ink);
  color: var(--parchment);
  border: 1px solid var(--gold);
  padding: 12px 22px;
  font-family: 'Cinzel', serif;
  font-size: 0.8rem;
  letter-spacing: 1px;
  box-shadow: 0 4px 20px var(--shadow);
  z-index: 200;
  opacity: 0;
  transform: translateY(10px);
  transition: opacity 0.3s, transform 0.3s;
  pointer-events: none;
}
.toast.show { opacity: 1; transform: translateY(0); }

/* ── FILTRE ── */
.filter-bar {
  display: flex;
  gap: 10px;
  align-items: center;
  margin-bottom: 20px;
  flex-wrap: wrap;
}
.filter-bar input, .filter-bar select { flex: 1; min-width: 140px; max-width: 260px; }

/* ── ÉTAT VIDE ── */
.empty-state {
  font-family: 'IM Fell English', serif;
  font-style: italic;
  color: var(--ink-light);
  padding: 30px 0;
  text-align: center;
  font-size: 1.1rem;
}

@media (max-width: 600px) {
  .parchment { padding: 22px 18px; }
  .modal-box { max-width: 100%; }
  .event-card-body { grid-template-columns: 1fr 1fr; }
  .login-title { font-size: 1.6rem; }
  .orga-table th:nth-child(3),
  .orga-table td:nth-child(3),
  .orga-table th:nth-child(4),
  .orga-table td:nth-child(4) { display: none; }
}
</style>
</head>
<body>
<div id="app">

  <!-- ══ LOGIN ══ -->
  <div id="login-screen">
    <div class="parchment">
      <div class="login-title">⚔ Événements de Faérie ⚔</div>
      <div class="login-subtitle">Gestion des dates</div>
      <hr class="divider">
      <div class="divider-ornament">✦ ✦ ✦</div>
      <div class="tab-switch">
        <button class="active" onclick="switchLogin('joueur', this)">Joueur·euse</button>
        <button onclick="switchLogin('orga', this)">Organisateur</button>
      </div>

      <!-- Formulaire joueur -->
      <div id="form-joueur">
        <div class="form-group">
          <label>Adresse e-mail</label>
          <input type="email" id="login-email" placeholder="votre@email.com" onkeydown="if(event.key==='Enter') doLoginJoueur()">
        </div>
        <div class="form-group">
          <label>Mot de passe</label>
          <input type="password" id="login-mdp" placeholder="••••••••" onkeydown="if(event.key==='Enter') doLoginJoueur()">
        </div>
        <button class="btn btn-full" onclick="doLoginJoueur()">Accéder aux événements</button>
        <div class="msg-error" id="err-joueur"></div>
      </div>

      <!-- Formulaire orga -->
      <div id="form-orga" style="display:none">
        <div class="form-group">
          <label>Mot de passe organisateur</label>
          <input type="password" id="login-orga-pwd" placeholder="••••••••" onkeydown="if(event.key==='Enter') doLoginOrga()">
        </div>
        <button class="btn btn-orga btn-full" onclick="doLoginOrga()">Accès organisateur</button>
        <div class="msg-error" id="err-orga"></div>
      </div>
    </div>
  </div>

  <!-- ══ VUE JOUEUR ══ -->
  <div id="joueur-screen" style="display:none">
    <div class="logout-bar">
      <span id="joueur-label">Joueur·euse</span>
      <button class="btn btn-sm" onclick="logout()">Déconnexion</button>
    </div>
    <div class="parchment">
      <div class="dashboard-title">Événements à venir</div>
      <div class="dashboard-subtitle">Consultez et inscrivez-vous aux prochaines aventures</div>

      <div class="filter-bar">
        <input type="text" id="filter-search" placeholder="Rechercher…" oninput="filterEvents()">
        <select id="filter-type" onchange="filterEvents()">
          <option value="">Tous les types</option>
          <option value="GN">GN</option>
          <option value="Atelier">Atelier</option>
          <option value="Réunion">Réunion</option>
          <option value="Autre">Autre</option>
        </select>
      </div>

      <div class="events-grid" id="joueur-events-grid">
        <div class="empty-state">Chargement des événements…</div>
      </div>
    </div>
  </div>

  <!-- ══ VUE ORGA ══ -->
  <div id="orga-screen" style="display:none">
    <div class="logout-bar">
      <span>⚔ Vue Organisateur — Événements</span>
      <button class="btn btn-sm" onclick="logout()">Déconnexion</button>
    </div>
    <div class="parchment">
      <div style="font-family:'Cinzel',serif;font-size:1.4rem;font-weight:700;letter-spacing:2px;margin-bottom:24px;color:var(--ink);">⚔ Gestion des Événements</div>
      <div class="orga-toolbar">
        <button class="btn btn-sm" onclick="openModalCreateEvent()">+ Nouvel événement</button>
        <input type="text" id="orga-search" placeholder="Filtrer…" style="max-width:220px;margin-left:auto" oninput="filterOrgaEvents(this.value)">
      </div>
      <table class="orga-table">
        <thead>
          <tr>
            <th>Titre</th>
            <th>Date</th>
            <th>Lieu</th>
            <th>Type</th>
            <th>Places</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="orga-events-body">
          <tr><td colspan="6" style="text-align:center;padding:20px;font-style:italic;color:var(--ink-light);">Chargement…</td></tr>
        </tbody>
      </table>
    </div>
  </div>

</div>

<!-- ══ MODALES ══ -->

<!-- Créer / Modifier événement -->
<div class="modal-overlay" id="modal-event">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal('modal-event')">✕</button>
    <div class="modal-title" id="modal-event-title">+ Nouvel événement</div>
    <input type="hidden" id="e-id">
    <div class="form-group">
      <label>Titre</label>
      <input type="text" id="e-titre" placeholder="Nom de l'événement">
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
      <div class="form-group">
        <label>Date</label>
        <input type="date" id="e-date">
      </div>
      <div class="form-group">
        <label>Type</label>
        <select id="e-type">
          <option value="GN">GN</option>
          <option value="Atelier">Atelier</option>
          <option value="Réunion">Réunion</option>
          <option value="Autre">Autre</option>
        </select>
      </div>
    </div>
    <div class="form-group">
      <label>Lieu</label>
      <input type="text" id="e-lieu" placeholder="Adresse ou lieu-dit">
    </div>
    <div class="form-group">
      <label>Organisateurs</label>
      <input type="text" id="e-organisateurs" placeholder="Noms séparés par des virgules">
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
      <div class="form-group">
        <label>Places totales</label>
        <input type="number" id="e-places-totales" min="1" value="20">
      </div>
      <div class="form-group" id="row-places-dispo" style="display:none">
        <label>Places disponibles</label>
        <input type="number" id="e-places-dispo" min="0">
      </div>
    </div>
    <button class="btn btn-full" style="margin-top:6px" onclick="saveEvent()">Enregistrer</button>
    <div class="msg-error" id="err-event"></div>
    <div class="msg-success" id="ok-event"></div>
  </div>
</div>

<!-- Confirmation inscription -->
<div class="modal-overlay" id="modal-inscription">
  <div class="modal-box" style="max-width:480px;text-align:center">
    <button class="modal-close" onclick="closeModal('modal-inscription')">✕</button>
    <div class="modal-title" id="modal-insc-titre">Inscription</div>
    <div style="font-family:'IM Fell English',serif;font-style:italic;font-size:1.05rem;margin-bottom:24px;color:var(--ink-light)" id="modal-insc-detail"></div>
    <div style="display:flex;gap:12px;justify-content:center">
      <button class="btn" onclick="confirmInscription()">Confirmer</button>
      <button class="btn-ghost" onclick="closeModal('modal-inscription')">Annuler</button>
    </div>
    <div class="msg-error" id="err-insc"></div>
    <div class="msg-success" id="ok-insc"></div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
// ════════════════════════════════════════════
//  CONFIG
// ════════════════════════════════════════════
const GS_URL = 'https://script.google.com/a/macros/xn--farie-csa.fr/s/AKfycbxjV5UDfna9nfWMGAVch3Ie89kjdEVdd95yeqPgJQyTyCJPAACxRdPaGyGE_py8KySRUw/exec';

// ════════════════════════════════════════════
//  STATE
// ════════════════════════════════════════════
const state = {
  role: null,
  userId: null,
  nom: null,
  prenom: null,
  email: null,
  events: [],
  filteredEvents: [],
  orgaEvents: [],
  pendingEventId: null
};

// ════════════════════════════════════════════
//  APPELS API
// ════════════════════════════════════════════
async function gs(action, params = {}) {
  const url = new URL(GS_URL);
  url.searchParams.set('action', action);
  for (const [k, v] of Object.entries(params)) url.searchParams.set(k, v);
  const res = await fetch(url.toString());
  return res.json();
}

async function gsPost(action, data) {
  const url = new URL(GS_URL);
  url.searchParams.set('action', action);
  const res = await fetch(url.toString(), {
    method: 'POST',
    body: JSON.stringify(data)
  });
  return res.json();
}

// ════════════════════════════════════════════
//  LOGIN
// ════════════════════════════════════════════
function switchLogin(mode, btn) {
  document.querySelectorAll('.tab-switch button').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('form-joueur').style.display = mode === 'joueur' ? '' : 'none';
  document.getElementById('form-orga').style.display   = mode === 'orga'   ? '' : 'none';
}

async function doLoginJoueur() {
  const email = document.getElementById('login-email').value.trim();
  const mdp   = document.getElementById('login-mdp').value;
  if (!email || !mdp) { showMsg('err-joueur', 'Remplissez tous les champs.'); return; }
  hideMsg('err-joueur');
  try {
    const r = await gs('loginJoueur', { email, motDePasse: mdp });
    if (r.success) {
      state.role   = 'joueur';
      state.userId = r.userId;
      state.nom    = r.nom;
      state.prenom = r.prenom;
      state.email  = email;
      document.getElementById('joueur-label').textContent = `⚔ ${r.prenom} ${r.nom}`;
      await loadJoueurEvents();
      show('joueur-screen');
      hide('login-screen');
    } else {
      showMsg('err-joueur', r.error || 'Email ou mot de passe incorrect.');
    }
  } catch(e) { showMsg('err-joueur', 'Erreur réseau : ' + e.message); }
}

async function doLoginOrga() {
  const pwd = document.getElementById('login-orga-pwd').value;
  hideMsg('err-orga');
  try {
    const cfg = await gs('getConfig');
    if (cfg && pwd === cfg.motDePasseAdmin) {
      state.role = 'orga';
      await loadOrgaEvents();
      show('orga-screen');
      hide('login-screen');
    } else {
      showMsg('err-orga', 'Mot de passe incorrect.');
    }
  } catch(e) { showMsg('err-orga', 'Erreur réseau : ' + e.message); }
}

function logout() {
  state.role = null; state.userId = null;
  hide('joueur-screen'); hide('orga-screen');
  show('login-screen');
}

// ════════════════════════════════════════════
//  VUE JOUEUR — chargement + rendu
// ════════════════════════════════════════════
async function loadJoueurEvents() {
  const grid = document.getElementById('joueur-events-grid');
  grid.innerHTML = '<div class="empty-state">Chargement…</div>';
  try {
    const r = await gs('getEvenements');
    state.events = (r && r.evenements) ? r.evenements : [];
    state.filteredEvents = [...state.events];
    renderJoueurEvents(state.filteredEvents);
  } catch(e) {
    grid.innerHTML = `<div class="empty-state" style="color:var(--red-blood)">Erreur : ${e.message}</div>`;
  }
}

function renderJoueurEvents(list) {
  const grid = document.getElementById('joueur-events-grid');
  if (!list.length) {
    grid.innerHTML = '<div class="empty-state">Aucun événement à venir pour l\'instant.</div>';
    return;
  }
  grid.innerHTML = list.map(ev => {
    const placesTot  = Number(ev.Places_totales) || 0;
    const placesDispo = Number(ev.Places_disponibles) || 0;
    const pct = placesTot > 0 ? Math.round((1 - placesDispo / placesTot) * 100) : 100;
    const complet = placesDispo <= 0;
    return `
    <div class="event-card">
      <div class="event-card-header">
        <div class="event-card-titre">${ev.Titre}</div>
        <div class="event-card-type">${ev.Type || '—'}</div>
      </div>
      <div class="event-card-body">
        <div class="event-info-item">
          <span class="event-info-label">Date</span>
          <span class="event-info-val">📅 ${ev.Date}</span>
        </div>
        <div class="event-info-item">
          <span class="event-info-label">Lieu</span>
          <span class="event-info-val">📍 ${ev.Lieu || '—'}</span>
        </div>
        <div class="event-info-item">
          <span class="event-info-label">Organisateurs</span>
          <span class="event-info-val">${ev.Organisateurs || '—'}</span>
        </div>
      </div>
      <div class="event-card-footer">
        <div class="jauge-wrap">
          <div class="jauge-bar">
            <div class="jauge-fill${complet ? ' complet' : ''}" style="width:${pct}%"></div>
          </div>
          <span class="jauge-text">${placesDispo} / ${placesTot} place${placesTot > 1 ? 's' : ''}</span>
          ${complet ? '<span class="badge-attente">COMPLET</span>' : ''}
        </div>
        <button class="btn btn-sm${complet ? ' btn-danger' : ''}" onclick="openInscription(${ev.ID}, '${ev.Titre.replace(/'/g, "\\'")}', ${placesDispo})">
          ${complet ? "Liste d'attente" : "S'inscrire"}
        </button>
      </div>
    </div>`;
  }).join('');
}

function filterEvents() {
  const q    = document.getElementById('filter-search').value.toLowerCase();
  const type = document.getElementById('filter-type').value;
  state.filteredEvents = state.events.filter(ev => {
    const matchQ    = !q || ev.Titre.toLowerCase().includes(q) || (ev.Lieu || '').toLowerCase().includes(q);
    const matchType = !type || ev.Type === type;
    return matchQ && matchType;
  });
  renderJoueurEvents(state.filteredEvents);
}

// ════════════════════════════════════════════
//  INSCRIPTION
// ════════════════════════════════════════════
function openInscription(eventId, titre, placesDispo) {
  state.pendingEventId = eventId;
  document.getElementById('modal-insc-titre').textContent = titre;
  document.getElementById('modal-insc-detail').textContent =
    placesDispo > 0
      ? `Il reste ${placesDispo} place(s). Confirmez-vous votre inscription ?`
      : "Cet événement est complet. Souhaitez-vous rejoindre la liste d'attente ?";
  hideMsg('err-insc'); hideMsg('ok-insc');
  openModal('modal-inscription');
}

async function confirmInscription() {
  try {
    const r = await gsPost('subscribeToEvent', { userId: state.userId, eventId: state.pendingEventId });
    if (r.success) {
      showMsg('ok-insc', '✦ ' + r.success, 'success');
      showToast('✦ Inscription confirmée');
      await loadJoueurEvents();
    } else if (r.warning) {
      showMsg('ok-insc', '⚠ ' + r.warning, 'success');
      showToast('⚠ ' + r.warning);
    } else {
      showMsg('err-insc', r.error || 'Une erreur est survenue.');
    }
  } catch(e) { showMsg('err-insc', 'Erreur : ' + e.message); }
}

// ════════════════════════════════════════════
//  VUE ORGA — chargement + rendu
// ════════════════════════════════════════════
async function loadOrgaEvents() {
  const tbody = document.getElementById('orga-events-body');
  tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:20px;font-style:italic;color:var(--ink-light);">Chargement…</td></tr>';
  try {
    const r = await gs('getEvenements');
    state.orgaEvents = (r && r.evenements) ? r.evenements : [];
    renderOrgaTable(state.orgaEvents);
  } catch(e) {
    tbody.innerHTML = `<tr><td colspan="6" style="color:var(--red-blood);padding:20px">Erreur : ${e.message}</td></tr>`;
  }
}

function renderOrgaTable(list) {
  const tbody = document.getElementById('orga-events-body');
  if (!list.length) {
    tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:20px;font-style:italic;color:var(--ink-light);">Aucun événement.</td></tr>';
    return;
  }
  tbody.innerHTML = list.map(ev => `
    <tr>
      <td><strong style="font-family:'Cinzel',serif;font-size:0.88rem">${ev.Titre}</strong></td>
      <td>${ev.Date}</td>
      <td>${ev.Lieu || '—'}</td>
      <td>${ev.Type || '—'}</td>
      <td>${ev.Jauge || `${ev.Places_disponibles}/${ev.Places_totales}`}</td>
      <td style="display:flex;gap:6px;flex-wrap:wrap">
        <button class="btn btn-sm" onclick="openModalEditEvent(${ev.ID})">✏ Modifier</button>
      </td>
    </tr>
  `).join('');
}

function filterOrgaEvents(q) {
  const filtered = state.orgaEvents.filter(ev =>
    (ev.Titre + ev.Lieu + ev.Type).toLowerCase().includes(q.toLowerCase())
  );
  renderOrgaTable(filtered);
}

// ════════════════════════════════════════════
//  MODAL ÉVÉNEMENT (créer / modifier)
// ════════════════════════════════════════════
function openModalCreateEvent() {
  document.getElementById('modal-event-title').textContent = '+ Nouvel événement';
  document.getElementById('e-id').value = '';
  document.getElementById('e-titre').value = '';
  document.getElementById('e-date').value  = '';
  document.getElementById('e-lieu').value  = '';
  document.getElementById('e-organisateurs').value = '';
  document.getElementById('e-type').value  = 'GN';
  document.getElementById('e-places-totales').value = '20';
  document.getElementById('row-places-dispo').style.display = 'none';
  hideMsg('err-event'); hideMsg('ok-event');
  openModal('modal-event');
}

function openModalEditEvent(id) {
  const ev = state.orgaEvents.find(e => String(e.ID) === String(id));
  if (!ev) return;
  document.getElementById('modal-event-title').textContent = '✏ Modifier l\'événement';
  document.getElementById('e-id').value    = ev.ID;
  document.getElementById('e-titre').value = ev.Titre;
  // Convertir date FR → ISO pour input[type=date]
  const parts = ev.Date.split('/');
  document.getElementById('e-date').value  = parts.length === 3 ? `${parts[2]}-${parts[1]}-${parts[0]}` : '';
  document.getElementById('e-lieu').value  = ev.Lieu || '';
  document.getElementById('e-organisateurs').value = ev.Organisateurs || '';
  document.getElementById('e-type').value  = ev.Type || 'GN';
  document.getElementById('e-places-totales').value = ev.Places_totales || '';
  document.getElementById('e-places-dispo').value   = ev.Places_disponibles || '';
  document.getElementById('row-places-dispo').style.display = '';
  hideMsg('err-event'); hideMsg('ok-event');
  openModal('modal-event');
}

async function saveEvent() {
  const id           = document.getElementById('e-id').value;
  const titre        = document.getElementById('e-titre').value.trim();
  const date         = document.getElementById('e-date').value;
  const lieu         = document.getElementById('e-lieu').value.trim();
  const organisateurs= document.getElementById('e-organisateurs').value.trim();
  const typeJeu      = document.getElementById('e-type').value;
  const placesTotales= parseInt(document.getElementById('e-places-totales').value) || 0;

  if (!titre || !date) { showMsg('err-event', 'Titre et date sont obligatoires.'); return; }
  hideMsg('err-event');

  try {
    let r;
    if (id) {
      const placesDisponibles = parseInt(document.getElementById('e-places-dispo').value) || 0;
      r = await gsPost('updateEvent', { id: parseInt(id), titre, date, lieu, organisateurs, typeJeu, placesTotales, placesDisponibles });
    } else {
      r = await gsPost('createEvent', { titre, date, lieu, organisateurs, typeJeu, placesTotales });
    }
    if (r.success) {
      showMsg('ok-event', '✦ ' + r.success, 'success');
      showToast('✦ ' + r.success);
      await loadOrgaEvents();
    } else {
      showMsg('err-event', r.error || 'Erreur inconnue.');
    }
  } catch(e) { showMsg('err-event', 'Erreur : ' + e.message); }
}

// ════════════════════════════════════════════
//  UTILITAIRES UI
// ════════════════════════════════════════════
function show(id) { document.getElementById(id).style.display = ''; }
function hide(id) { document.getElementById(id).style.display = 'none'; }

function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

function showMsg(id, txt, type = 'error') {
  const el = document.getElementById(id);
  if (!el) return;
  el.textContent = txt;
  el.style.display = '';
  el.className = type === 'success' ? 'msg-success' : 'msg-error';
}
function hideMsg(id) {
  const el = document.getElementById(id);
  if (el) el.style.display = 'none';
}

let toastTimer;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 3000);
}

// Fermer modale en cliquant l'overlay
document.querySelectorAll('.modal-overlay').forEach(el => {
  el.addEventListener('click', e => { if (e.target === el) el.classList.remove('open'); });
});
</script>
